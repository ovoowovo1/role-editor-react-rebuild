{
  "name": "tw-role-editor-react-rebuild",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:gaf": "node scripts/generateGafManifest.mjs",
    "predev": "npm run generate:gaf",
    "prebuild": "npm run generate:gaf",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "renderer:dev": "tsx renderer/server.ts",
    "renderer:build": "tsc -p tsconfig.renderer.json",
    "renderer:start": "npm run build && npm run renderer:build && node renderer-dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "preview": "vite preview",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:deploy:frontend": "wrangler deploy --config wrangler.frontend.jsonc --keep-vars",
    "typecheck:worker": "tsc -p tsconfig.worker.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate:color-blocks": "node scripts/migrateColorBlockPresets.mjs",
    "db:push": "drizzle-kit push",
    "db:seed:color-blocks": "node scripts/seedColorBlockPresets.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@pixi/filter-glow": "^5.2.1",
    "chart.js": "^4.5.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pako": "^2.1.0",
    "pg": "^8.20.0",
    "pixi.js": "^7.4.3",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260516.1",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/pako": "^2.0.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jszip": "^3.10.1",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  }
}
